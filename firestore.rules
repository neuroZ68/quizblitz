rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quizzes — readable/writable by any authenticated user (host)
    match /quizzes/{quizId} {
      allow read, write: if request.auth != null;
    }

    // Sessions — readable by any authenticated user
    match /sessions/{pin} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Players sub-collection
      match /players/{playerId} {
        // Players can read all players (for leaderboard)
        allow read: if request.auth != null;
        // Players can only write their own doc
        allow create: if request.auth != null && request.auth.uid == playerId;
        allow update: if request.auth != null && request.auth.uid == playerId;
      }
    }
  }
}
